import { QueryClient } from "@tanstack/react-query";
import { type InferClient } from "@garph/gqty";
import {
  createGeneratedSchema,
  createScalarsEnumsHash,
} from "@garph/gqty/dist/utils";
import { Cache, createClient, type QueryFetcher } from "gqty";
import {
  g,
  buildSchema,
  queryType,
  mutationType,
} from "@{{projectName}}/api/index";
import { API_URL } from "@/lib/api";

export const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      retry: 2,
      staleTime: 1000 * 60,
    },
  },
});

const schema = buildSchema({ g, resolvers: {} });
const generatedSchema = createGeneratedSchema(schema);
const scalarsEnumsHash = createScalarsEnumsHash(schema);

type Schema = InferClient<{ query: typeof queryType; mutation: typeof mutationType }>;

const url = `${API_URL}/graphql`;

const queryFetcher: QueryFetcher = async (
  { query, variables, operationName },
  fetchOptions
) => {
  const response = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ query, variables, operationName }),
    mode: "cors",
{{#if (isBetterAuth auth)}}
    credentials: "include",
{{/if}}
    ...fetchOptions,
  });
  return response.json();
};

export const client = createClient<Schema>({
  schema: generatedSchema,
  scalars: scalarsEnumsHash,
  cache: new Cache(undefined, {
    maxAge: 0,
    staleWhileRevalidate: 5 * 60 * 1000,
    normalization: true,
  }),
  fetchOptions: { fetcher: queryFetcher },
});

export const { query, mutation, resolved } = client;

export async function graphqlFetcher<T>(
  fn: () => T | Promise<T>
): Promise<T> {
  return resolved(fn);
}
