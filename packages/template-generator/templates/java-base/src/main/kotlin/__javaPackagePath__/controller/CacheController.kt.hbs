package {{javaPackageName}}.controller

import java.time.Instant
import org.springframework.web.bind.annotation.GetMapping
import org.springframework.web.bind.annotation.RestController
import {{javaPackageName}}.cache.CachedTimeService

@RestController
class CacheController(private val cachedTimeService: CachedTimeService) {

    @GetMapping("/cache/time")
    fun cachedTime(): Map<String, Instant> = mapOf("generatedAt" to cachedTimeService.generatedAt())
}
