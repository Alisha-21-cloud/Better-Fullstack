{{#if isJavaOpenApiGenerator}}
// Generate Spring MVC API interfaces from the OpenAPI contract before compiling.
openApiGenerate {
	generatorName.set("spring")
	inputSpec.set("$projectDir/src/main/resources/openapi.yaml")
	outputDir.set(layout.buildDirectory.dir("generated/openapi").get().asFile.absolutePath)
	apiPackage.set("{{javaPackageName}}.api")
	modelPackage.set("{{javaPackageName}}.model")
	configOptions.set(
		mapOf(
			"interfaceOnly" to "true",
			"useSpringBoot3" to "true",
			"useJakartaEe" to "true",
			"useTags" to "true",
			"documentationProvider" to "source",
			"annotationLibrary" to "swagger2",
			"useBeanValidation" to "false",
			"openApiNullable" to "false",
			"skipDefaultInterface" to "false",
		),
	)
}

sourceSets.named("main") {
	java.srcDir(layout.buildDirectory.dir("generated/openapi/src/main/java"))
}

tasks.named("compileJava") {
	dependsOn("openApiGenerate")
}

{{/if}}
{{#if hasJavaGrpc}}
// Run protoc (downloaded by the plugin) + the grpc-java plugin over
// src/main/proto before compiling. The protobuf plugin adds the generated
// message + stub sources to the main source set and makes compileJava depend
// on the generateProto task, so the stubs land on the compile classpath.
protobuf {
	protoc {
		artifact = "com.google.protobuf:protoc:4.28.2"
	}
	plugins {
		id("grpc") {
			artifact = "io.grpc:protoc-gen-grpc-java:1.68.1"
		}
	}
	generateProtoTasks {
		all().forEach {
			it.plugins {
				id("grpc")
			}
		}
	}
}

