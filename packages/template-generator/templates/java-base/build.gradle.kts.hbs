{{#if hasJavaLog4j2}}
// Spring Boot pulls Logback in transitively through every starter (actuator,
// data-jpa, ...), not just spring-boot-starter-webmvc. Exclude it globally when
// Log4j2 is selected to avoid a dual SLF4J binding that fails at runtime.
configurations.all {
	exclude(group = "org.springframework.boot", module = "spring-boot-starter-logging")
}

