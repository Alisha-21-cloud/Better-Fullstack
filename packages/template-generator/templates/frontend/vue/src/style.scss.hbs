{{#if (eq cssFramework "scss")}}
$accent: #34d399;
:root { font-family: Inter, ui-sans-serif, system-ui, sans-serif; color: #e5e7eb; background: #09090b; }
body { margin: 0; }
.shell { max-width: 52rem; margin: 0 auto; padding: 8rem 2rem; .eyebrow, a { color: $accent; } }
h1 { font-size: clamp(3rem, 10vw, 6rem); }
{{/if}}
