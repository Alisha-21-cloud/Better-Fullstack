{{#unless (or (eq cssFramework "scss") (eq cssFramework "less"))}}
{{#if (eq cssFramework "tailwind")}}
@import "tailwindcss";
{{#if (eq uiLibrary "daisyui")}}
@plugin "daisyui";
{{/if}}
{{/if}}
:root { font-family: Inter, ui-sans-serif, system-ui, sans-serif; color: #e5e7eb; background: #09090b; }
body { margin: 0; min-width: 320px; min-height: 100vh; }
.shell { max-width: 52rem; margin: 0 auto; padding: 8rem 2rem; }
.eyebrow { color: #34d399; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; }
h1 { margin: .5rem 0 1rem; font-size: clamp(3rem, 10vw, 6rem); line-height: .95; }
p { color: #a1a1aa; font-size: 1.125rem; }
a { color: #6ee7b7; }
{{/unless}}
