# Application settings
HOST=0.0.0.0
PORT=8080

# Allowed web origin for CORS (unset or empty = allow any origin)
CORS_ORIGIN=

# Database settings (if using GORM, sqlc, Ent, Bun, or sqlx)
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# gRPC settings (if using gRPC)
GRPC_PORT=50051

# Logging level
LOG_LEVEL=debug
{{#if (eq goAuth "casbin")}}

# Casbin settings
CASBIN_MODEL=auth_model.conf
CASBIN_POLICY=auth_policy.csv
{{/if}}
{{#if (eq goAuth "jwt")}}

# JWT settings
JWT_SECRET=change-me-to-a-real-secret
{{/if}}
{{#if (eq goAuth "goth")}}

# Goth OAuth settings
OAUTH_CALLBACK_BASE_URL=http://localhost:8080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
{{/if}}
{{#if (eq goAuth "oauth2")}}

# OAuth2 client settings
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/oauth/callback
OAUTH_AUTH_URL=
OAUTH_TOKEN_URL=
{{/if}}
{{#if (eq goCaching "redis")}}

# go-redis settings
REDIS_URL=redis://127.0.0.1:6379
{{/if}}
{{#if (eq goMessageQueue "nats")}}

# NATS settings
NATS_URL=nats://127.0.0.1:4222
{{/if}}
{{#if (eq goMessageQueue "kafka-go")}}

# Kafka settings
KAFKA_BROKERS=localhost:9092
{{/if}}
{{#if (eq goMessageQueue "asynq")}}

# Asynq Redis settings
REDIS_ADDR=127.0.0.1:6379
{{/if}}
{{#if (eq goObservability "opentelemetry")}}

# OpenTelemetry settings
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
{{/if}}
{{#if (eq goApi "grpc-gateway")}}

# grpc-gateway HTTP address
GATEWAY_ADDR=:8081
{{/if}}
{{#if (eq goApi "connect-go")}}

# Connect RPC HTTP address
CONNECT_ADDR=:8081
{{/if}}
{{#if (eq goApi "oapi-codegen")}}

# OpenAPI HTTP address
OPENAPI_ADDR=:8081
{{/if}}
{{#if (eq auth "go-better-auth")}}

# GoBetterAuth settings
GO_BETTER_AUTH_BASE_URL=http://localhost:8080
GO_BETTER_AUTH_SECRET=change-me-to-a-real-secret-at-least-32-chars
GO_BETTER_AUTH_DATABASE_URL=./gobetterauth.db

# Email settings for GoBetterAuth
FROM_ADDRESS=noreply@localhost
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
{{/if}}
