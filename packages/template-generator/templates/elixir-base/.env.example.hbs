{{#if (ne elixirWebFramework "none")}}
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=replace-with-mix-phx-gen-secret

# Allowed web origin for CORS (unset or empty = allow any origin)
CORS_ORIGIN=
{{/if}}
{{#if (eq elixirOrm "ecto-sql")}}
DATABASE_URL=ecto://postgres:postgres@localhost/{{elixirAppName}}_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_DB={{elixirAppName}}_dev
POSTGRES_TEST_DB={{elixirAppName}}_test
{{/if}}
{{#if (eq elixirOrm "myxql")}}
DATABASE_URL=ecto://root:mysql@localhost/{{elixirAppName}}_prod
MYSQL_USER=root
MYSQL_PASSWORD=mysql
MYSQL_HOST=localhost
MYSQL_DATABASE={{elixirAppName}}_dev
MYSQL_TEST_DATABASE={{elixirAppName}}_test
{{/if}}
{{#if (eq elixirOrm "ecto_sqlite3")}}
DATABASE_PATH={{elixirAppName}}_dev.db
{{/if}}
{{#if (eq elixirObservability "sentry")}}
SENTRY_DSN=
{{/if}}
{{#if (includes elixirLibraries "ex_aws")}}
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
{{/if}}
{{#if (eq elixirCaching "redix")}}
REDIS_URL=redis://localhost:6379
{{/if}}
