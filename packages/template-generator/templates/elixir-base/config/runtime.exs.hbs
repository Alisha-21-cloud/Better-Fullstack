import Config

# Load KEY=VALUE pairs from a local .env in dev so scaffold-time settings
# (e.g. CORS_ORIGIN) apply to `mix phx.server`. Real environment variables win.
if config_env() == :dev and File.exists?(".env") do
  ".env"
  |> File.read!()
  |> String.split("\n")
  |> Enum.each(fn line ->
    line = String.trim(line)

    with false <- line == "" or String.starts_with?(line, "#"),
         [key, value] when value != "" <- String.split(line, "=", parts: 2),
         nil <- System.get_env(key) do
      System.put_env(key, value)
    end
  end)
end

if config_env() == :prod do
{{#if (eq elixirOrm "ecto-sql")}}
  database_url = System.get_env("DATABASE_URL")

  if database_url do
    config :{{elixirAppName}}, {{elixirModuleName}}.Repo,
      url: database_url,
      pool_size: String.to_integer(System.get_env("POOL_SIZE") || "10"),
      ssl: System.get_env("ECTO_SSL") == "true"
  end
{{/if}}
{{#if (eq elixirOrm "myxql")}}
  database_url = System.get_env("DATABASE_URL")

  if database_url do
    config :{{elixirAppName}}, {{elixirModuleName}}.Repo,
      url: database_url,
      pool_size: String.to_integer(System.get_env("POOL_SIZE") || "10")
  end
{{/if}}
{{#if (eq elixirOrm "ecto_sqlite3")}}
  database_path =
    System.get_env("DATABASE_PATH") ||
      Path.join(System.get_env("RELEASE_ROOT") || File.cwd!(), "data/{{elixirAppName}}.db")

  File.mkdir_p!(Path.dirname(database_path))

  config :{{elixirAppName}}, {{elixirModuleName}}.Repo,
    database: database_path,
    pool_size: String.to_integer(System.get_env("POOL_SIZE") || "5")
{{/if}}

{{#if (eq elixirObservability "sentry")}}
  config :sentry, dsn: System.get_env("SENTRY_DSN")
{{/if}}

{{#if (ne elixirWebFramework "none")}}
  secret_key_base =
    System.get_env("SECRET_KEY_BASE") ||
      raise "SECRET_KEY_BASE is missing. Generate one with: mix phx.gen.secret"

  host = System.get_env("PHX_HOST") || "example.com"
  port = String.to_integer(System.get_env("PORT") || "4000")

  config :{{elixirAppName}}, {{elixirModuleName}}Web.Endpoint,
    url: [host: host, port: 443, scheme: "https"],
    http: [ip: {0, 0, 0, 0}, port: port],
    secret_key_base: secret_key_base,
    server: true
{{/if}}
end
