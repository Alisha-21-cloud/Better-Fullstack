{{#if (eq rustTemplating "askama")}}
//! Compile-time HTML templates with Askama.
//!
//! Template sources live in `templates/` at the crate root and are checked
//! at compile time.

#![allow(dead_code)]

use askama::Template;

#[derive(Template)]
#[template(path = "hello.html")]
pub struct HelloTemplate<'a> {
    pub name: &'a str,
}

/// Render the hello template to an HTML string.
pub fn render_hello(name: &str) -> Result<String, askama::Error> {
    HelloTemplate { name }.render()
}
