{{#if (eq rustTemplating "minijinja")}}
//! Lightweight runtime templates with MiniJinja.

#![allow(dead_code)]

use minijinja::{context, Environment, Error};

pub fn render_hello(name: &str) -> Result<String, Error> {
    let mut environment = Environment::new();
    environment.add_template("hello.html", "<h1>Hello, \{{name}}!</h1>")?;
    environment
        .get_template("hello.html")?
        .render(context! { name => name })
}
{{/if}}
{{#if (eq rustTemplating "tera")}}
//! Runtime HTML templates with Tera.

#![allow(dead_code)]

use tera::{Context, Tera};

/// Render a small inline template; swap for `Tera::new("templates/**/*")`
/// to load templates from disk.
pub fn render_hello(name: &str) -> Result<String, tera::Error> {
    let mut tera = Tera::default();
    tera.add_raw_template("hello.html", "<h1>Hello, \{{name}}!</h1>")?;
    let mut context = Context::new();
    context.insert("name", name);
    tera.render("hello.html", &context)
}
{{/if}}
