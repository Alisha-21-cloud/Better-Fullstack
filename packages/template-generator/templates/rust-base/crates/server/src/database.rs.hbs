{{#if (eq rustOrm "sea-orm")}}
//! SeaORM connection and health-check helpers.

#![allow(dead_code)]

use std::sync::Arc;

use sea_orm::{Database as SeaDatabase, DatabaseConnection};

pub type Database = Arc<DatabaseConnection>;

pub async fn connect() -> Result<Database, Box<dyn std::error::Error + Send + Sync>> {
    let url = std::env::var("DATABASE_URL")?;
    Ok(Arc::new(SeaDatabase::connect(url).await?))
}

pub async fn is_healthy(connection: &Database) -> bool {
    connection.ping().await.is_ok()
}
