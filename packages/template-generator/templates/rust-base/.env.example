# Application
RUST_LOG=debug
APP_ENV=development

# Server
HOST=127.0.0.1
PORT=3000

# Allowed web origin for CORS (unset or empty = allow any origin)
CORS_ORIGIN=

# gRPC (if using tonic)
# GRPC_PORT=50051

# Database (if using)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# DATABASE_URL=sqlite:./data.db

# MongoDB (when rust-orm=mongodb)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=my_app

# JSON-RPC (when rust-api=jsonrpsee)
# JSONRPC_PORT=9944

# Kafka / NATS (when selected)
# KAFKA_BROKERS=localhost:9092
# NATS_URL=nats://127.0.0.1:4222

# OpenID Connect (when rust-auth=openidconnect)
# OIDC_ISSUER_URL=https://accounts.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URL=http://localhost:3000/auth/callback

# Prometheus metrics exporter (when rust-observability=metrics)
# METRICS_LISTEN_ADDRESS=127.0.0.1:9000

# JWT Secret (if using jsonwebtoken)
# JWT_SECRET=your-secret-key-here
